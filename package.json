{
  "name": "clock-weather-widget",
  "version": "1.2.1",
  "description": "Минималистичный виджет часов и погоды с системой тем",
  "main": "main.js",
  "author": "Виталий Стратиенко <dev@itbrutalik.ru>",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "ru.itbrutalik.clockweather",
    "productName": "ClockAndWeather",
    "directories": { "output": "dist" },
    "files": [ "**/*", "!node_modules/**/*", "!*.md", "!.git" ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "ClockAndWeather_Setup.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "ClockAndWeather_Portable.${ext}"
    }
  }
}